{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "WORKOS_*",
        "LINEAR_*",
        "NOTION_*",
        "AWS_*",
        "ENCRYPTION_KEY",
        "API_PORT",
        "FRONTEND_URL",
        "CORS_ORIGIN"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "WORKOS_*",
        "LINEAR_*",
        "NOTION_*",
        "AWS_*",
        "ENCRYPTION_KEY",
        "API_PORT",
        "FRONTEND_URL",
        "CORS_ORIGIN"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}

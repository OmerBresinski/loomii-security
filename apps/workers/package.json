{
  "name": "@loomii/workers",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "true",
    "dev": "bun run --watch --env-file=../../.env src/index.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "find src -name '*.test.ts' ! -name '*.e2e.test.ts' -exec bun test --env-file=../../.env {} \\;",
    "test:e2e": "bun test --env-file=../../.env $(find src -name '*.e2e.test.ts')",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.107",
    "@linear/sdk": "^84.0.0",
    "@loomii/db": "workspace:*",
    "@loomii/queue": "workspace:*",
    "@loomii/shared": "workspace:*",
    "@mastra/core": "^1.35.0",
    "@notionhq/client": "^5.21.0",
    "ai": "^6.0.184",
    "bullmq": "^5.76.9",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0"
  }
}

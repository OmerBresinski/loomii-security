{
  "name": "@loomii/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "true",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate deploy",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:studio": "bunx --bun prisma studio",
    "db:push": "bunx --bun prisma db push",
    "db:seed": "bun prisma/seed.ts",
    "clean": "rm -rf dist"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}

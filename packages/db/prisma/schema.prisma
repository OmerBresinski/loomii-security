generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// Enums
// ===========================================

enum Role {
  ADMIN
  SECURITY_LEAD
  DEVELOPER
  VIEWER
}

enum IntegrationProvider {
  LINEAR
  NOTION
}

enum IntegrationStatus {
  ACTIVE
  DISCONNECTED
  ERROR
  PENDING
}

enum EventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum BundleStatus {
  ASSEMBLING
  READY
  REVIEWING
  COMPLETED
  FAILED
}

enum ThreatModelStatus {
  PENDING
  GENERATING
  ACTIVE
  ERROR
}

enum StrideCategory {
  SPOOFING
  TAMPERING
  REPUDIATION
  INFORMATION_DISCLOSURE
  DENIAL_OF_SERVICE
  ELEVATION_OF_PRIVILEGE
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ReviewStatus {
  GENERATING
  READY
  PUBLISHED
  ERROR
}

enum DismissalReason {
  FALSE_POSITIVE
  NOT_APPLICABLE
  DUPLICATE
  ALREADY_MITIGATED
}

enum FindingType {
  THREAT
  REQUIREMENT
  MITIGATION
  OBSERVATION
}

enum FindingStatus {
  DISMISSED
  CONFIRMED
}

enum Effort {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RelationType {
  THREAT_TO_REQUIREMENT
  REQUIREMENT_TO_MITIGATION
  THREAT_TO_MITIGATION
  RELATED
}

enum SourceType {
  NOTION_PAGE
  LINEAR_ISSUE
}

enum LinkMethod {
  AUTO
  MANUAL
}

// ===========================================
// Models
// ===========================================

model Tenant {
  id                   String   @id @default(cuid())
  name                 String
  workosOrgId          String   @unique @map("workos_org_id")
  onboardingStep       Int      @default(0) @map("onboarding_step")
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  users                   User[]
  integrations            Integration[]
  events                  Event[]
  contextBundles          ContextBundle[]
  embeddings              Embedding[]
  projects                Project[]
  threatModel             ThreatModel?
  reviews                 Review[]
  policies                Policy[]
  policyOverrides         PolicyOverride[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  aiUsage                 AiUsage[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  workosUserId String   @map("workos_user_id")
  email        String
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  role         Role     @default(DEVELOPER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdProjects         Project[]                @relation("ProjectCreatedBy")
  assignedProjects        Project[]                @relation("ProjectAssignee")
  linkedSources           ProjectSource[]          @relation("ProjectSourceLinkedBy")
  notificationPreferences NotificationPreference[]
  notifications           Notification[]

  @@unique([tenantId, workosUserId])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Integration {
  id             String              @id @default(cuid())
  tenantId       String              @map("tenant_id")
  provider       IntegrationProvider
  status         IntegrationStatus   @default(PENDING)
  externalId     String?             @map("external_id")
  accessToken    String?             @map("access_token") // Encrypted
  refreshToken   String?             @map("refresh_token") // Encrypted
  tokenExpiresAt DateTime?           @map("token_expires_at")
  metadata       Json?
  lastSyncAt     DateTime?           @map("last_sync_at")
  lastSyncCursor String?             @map("last_sync_cursor")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  // Relations
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events Event[]

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([status])
  @@map("integrations")
}

model Event {
  id            String              @id @default(cuid())
  tenantId      String              @map("tenant_id")
  integrationId String              @map("integration_id")
  source        IntegrationProvider
  externalId    String              @map("external_id")
  type          String // e.g., "issue.created", "page.updated"
  status        EventStatus         @default(PENDING)
  payload       Json
  processedAt   DateTime?           @map("processed_at")
  errorMessage  String?             @map("error_message")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integration   Integration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  contextBundle ContextBundle?

  @@unique([tenantId, source, externalId, type])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("events")
}

model ContextBundle {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  eventId      String       @unique @map("event_id")
  projectId    String?      @map("project_id")
  status       BundleStatus @default(ASSEMBLING)
  riskLevel    RiskLevel?   @map("risk_level")
  title        String?
  summary      String?
  content      Json? // Assembled context for LLM review
  reviewOutput Json?        @map("review_output")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  review  Review?

  @@index([tenantId])
  @@index([status])
  @@index([riskLevel])
  @@index([createdAt])
  @@index([projectId])
  @@map("context_bundles")
}

// ===========================================
// Projects
// ===========================================

model Project {
  id               String                       @id @default(cuid())
  tenantId         String                       @map("tenant_id")
  name             String
  icon             String                       @default("Shield01Icon")
  color            String                       @default("#67E8F9")
  summary          String?                      @db.Text
  summaryEmbedding Unsupported("vector(1024)")? @map("summary_embedding")
  summaryUpdatedAt DateTime?                    @map("summary_updated_at")
  createdById      String?                      @map("created_by_id")
  assignedToId     String?                      @map("assigned_to_id")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo     User?           @relation("ProjectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  sources        ProjectSource[]
  contextBundles ContextBundle[]
  notifications  Notification[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([assignedToId])
  @@map("projects")
}

model ProjectSource {
  id             String     @id @default(cuid())
  projectId      String     @map("project_id")
  sourceType     SourceType @map("source_type")
  sourceId       String     @map("source_id")
  sourceUrl      String?    @map("source_url")
  linkedBy       LinkMethod @map("linked_by")
  linkedByUserId String?    @map("linked_by_user_id")
  linkReason     Json?      @map("link_reason")
  isArchived     Boolean    @default(false) @map("is_archived")
  archivedAt     DateTime?  @map("archived_at")
  archivedReason String?    @map("archived_reason")
  linkedAt       DateTime   @default(now()) @map("linked_at")
  unlinkedAt     DateTime?  @map("unlinked_at")

  // Relations
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedByUser User?   @relation("ProjectSourceLinkedBy", fields: [linkedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, sourceType, sourceId])
  @@index([sourceType, sourceId])
  @@index([projectId, isArchived])
  @@map("project_sources")
}

model Embedding {
  id         String                      @id @default(cuid())
  tenantId   String                      @map("tenant_id")
  documentId String                      @map("document_id")
  chunk      Int                         @default(0)
  content    String // Original text content
  vector     Unsupported("vector(1024)")
  metadata   Json?
  createdAt  DateTime                    @default(now()) @map("created_at")
  updatedAt  DateTime                    @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, documentId, chunk])
  @@index([tenantId])
  @@map("embeddings")
}

// ===========================================
// Policies
// ===========================================

model Policy {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  name       String
  framework  String // "OWASP_TOP_10_2021", "OWASP_LLM_TOP_10", "CUSTOM"
  identifier String   @unique // e.g., "A01", "LLM01", "custom_<cuid>"
  content    String // Full policy text (markdown)
  keywords   String[] // Trigger keywords for mandatory inclusion
  isBuiltIn  Boolean  @default(false) @map("is_built_in")
  isEnabled  Boolean  @default(true) @map("is_enabled")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  overrides PolicyOverride[]

  @@index([tenantId])
  @@index([framework])
  @@index([isEnabled])
  @@map("policies")
}

model PolicyOverride {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  policyId  String   @map("policy_id")
  isEnabled Boolean  @default(false) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, policyId])
  @@index([tenantId])
  @@index([policyId])
  @@map("policy_overrides")
}

// ===========================================
// Design Reviews
// ===========================================

model Review {
  id              String       @id @default(cuid())
  tenantId        String       @map("tenant_id")
  contextBundleId String       @unique @map("context_bundle_id")
  status          ReviewStatus @default(GENERATING)
  severity        Severity?
  confidence      Float? // 0-1 confidence score
  summary         String?
  modelUsed       String?      @map("model_used")
  riskLevel       String?      @map("risk_level")
  currentVersion  Int          @default(1) @map("current_version")
  errorMessage    String?      @map("error_message")
  publishedAt     DateTime?    @map("published_at")
  publishedBy     String?      @map("published_by")
  commentText     String?      @map("comment_text")
  commentPostedTo String[]     @default([]) @map("comment_posted_to")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contextBundle ContextBundle   @relation(fields: [contextBundleId], references: [id], onDelete: Cascade)
  versions      ReviewVersion[]
  findings      Finding[]

  @@index([tenantId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewVersion {
  id         String   @id @default(cuid())
  reviewId   String   @map("review_id")
  version    Int
  content    Json // Full review content snapshot
  editorType String   @map("editor_type") // "agent" | "human"
  editorId   String?  @map("editor_id") // User ID if human edit
  editReason String?  @map("edit_reason")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, version])
  @@index([reviewId])
  @@map("review_versions")
}

model Finding {
  id              String           @id @default(cuid())
  reviewId        String           @map("review_id")
  type            FindingType
  title           String
  description     String?
  severity        Severity
  confidence      Float? // 0-1 confidence score
  strideCategory  StrideCategory?  @map("stride_category")
  policyId        String?          @map("policy_id")
  policyName      String?          @map("policy_name")
  effortEstimate  Effort?          @map("effort_estimate")
  status          FindingStatus?
  dismissalReason DismissalReason? @map("dismissal_reason")
  dismissedBy     String?          @map("dismissed_by")
  dismissedAt     DateTime?        @map("dismissed_at")
  confirmedBy     String?          @map("confirmed_by")
  confirmedAt     DateTime?        @map("confirmed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  review            Review            @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  outgoingRelations FindingRelation[] @relation("FromFinding")
  incomingRelations FindingRelation[] @relation("ToFinding")

  @@index([reviewId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@map("findings")
}

model FindingRelation {
  id            String       @id @default(cuid())
  fromFindingId String       @map("from_finding_id")
  toFindingId   String       @map("to_finding_id")
  relationType  RelationType @map("relation_type")
  createdAt     DateTime     @default(now()) @map("created_at")

  // Relations
  fromFinding Finding @relation("FromFinding", fields: [fromFindingId], references: [id], onDelete: Cascade)
  toFinding   Finding @relation("ToFinding", fields: [toFindingId], references: [id], onDelete: Cascade)

  @@unique([fromFindingId, toFindingId])
  @@index([fromFindingId])
  @@index([toFindingId])
  @@map("finding_relations")
}

// ===========================================
// Threat Model
// ===========================================

model ThreatModel {
  id            String            @id @default(cuid())
  tenantId      String            @unique @map("tenant_id")
  status        ThreatModelStatus @default(PENDING)
  version       Int               @default(1)
  generatedAt   DateTime?         @map("generated_at")
  lastUpdatedAt DateTime          @updatedAt @map("last_updated_at")
  errorMessage  String?           @map("error_message")
  createdAt     DateTime          @default(now()) @map("created_at")

  // Relations
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  components      TmComponent[]
  dataFlows       TmDataFlow[]
  trustBoundaries TmTrustBoundary[]
  entryPoints     TmEntryPoint[]
  assets          TmAsset[]
  threats         TmThreat[]
  changes         TmChange[]
  gaps            TmGap[]

  @@index([status])
  @@map("threat_models")
}

model TmComponent {
  id            String   @id @default(cuid())
  threatModelId String   @map("threat_model_id")
  name          String
  type          String
  description   String?
  isDeprecated  Boolean  @default(false) @map("is_deprecated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  threatModel       ThreatModel  @relation(fields: [threatModelId], references: [id], onDelete: Cascade)
  outgoingDataFlows TmDataFlow[] @relation("FromComponent")
  incomingDataFlows TmDataFlow[] @relation("ToComponent")
  threats           TmThreat[]

  @@index([threatModelId])
  @@map("tm_components")
}

model TmDataFlow {
  id              String   @id @default(cuid())
  threatModelId   String   @map("threat_model_id")
  fromComponentId String   @map("from_component_id")
  toComponentId   String   @map("to_component_id")
  description     String?
  dataType        String?  @map("data_type")
  sensitivity     String?
  encryption      String?
  isDeprecated    Boolean  @default(false) @map("is_deprecated")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  threatModel   ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)
  fromComponent TmComponent @relation("FromComponent", fields: [fromComponentId], references: [id], onDelete: Cascade)
  toComponent   TmComponent @relation("ToComponent", fields: [toComponentId], references: [id], onDelete: Cascade)
  threats       TmThreat[]

  @@index([threatModelId])
  @@index([fromComponentId])
  @@index([toComponentId])
  @@map("tm_data_flows")
}

model TmTrustBoundary {
  id            String   @id @default(cuid())
  threatModelId String   @map("threat_model_id")
  name          String
  description   String?
  fromZone      String?  @map("from_zone")
  toZone        String?  @map("to_zone")
  isDeprecated  Boolean  @default(false) @map("is_deprecated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  threatModel ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)

  @@index([threatModelId])
  @@map("tm_trust_boundaries")
}

model TmEntryPoint {
  id            String   @id @default(cuid())
  threatModelId String   @map("threat_model_id")
  name          String
  type          String
  description   String?
  authRequired  Boolean  @default(false) @map("auth_required")
  authType      String?  @map("auth_type")
  rateLimited   Boolean  @default(false) @map("rate_limited")
  isDeprecated  Boolean  @default(false) @map("is_deprecated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  threatModel ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)
  threats     TmThreat[]

  @@index([threatModelId])
  @@map("tm_entry_points")
}

model TmAsset {
  id            String   @id @default(cuid())
  threatModelId String   @map("threat_model_id")
  name          String
  type          String
  sensitivity   String?
  description   String?
  isDeprecated  Boolean  @default(false) @map("is_deprecated")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  threatModel ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)

  @@index([threatModelId])
  @@map("tm_assets")
}

model TmThreat {
  id               String         @id @default(cuid())
  threatModelId    String         @map("threat_model_id")
  title            String
  description      String?
  strideCategory   StrideCategory @map("stride_category")
  severity         Severity
  likelihood       String?
  mitigationStatus String         @default("UNMITIGATED") @map("mitigation_status")
  mitigationNotes  String?        @map("mitigation_notes")
  componentId      String?        @map("component_id")
  dataFlowId       String?        @map("data_flow_id")
  entryPointId     String?        @map("entry_point_id")
  isDeprecated     Boolean        @default(false) @map("is_deprecated")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  threatModel ThreatModel   @relation(fields: [threatModelId], references: [id], onDelete: Cascade)
  component   TmComponent?  @relation(fields: [componentId], references: [id], onDelete: SetNull)
  dataFlow    TmDataFlow?   @relation(fields: [dataFlowId], references: [id], onDelete: SetNull)
  entryPoint  TmEntryPoint? @relation(fields: [entryPointId], references: [id], onDelete: SetNull)

  @@index([threatModelId])
  @@index([severity])
  @@index([mitigationStatus])
  @@index([strideCategory])
  @@map("tm_threats")
}

model TmChange {
  id            String   @id @default(cuid())
  threatModelId String   @map("threat_model_id")
  version       Int
  changeType    String   @map("change_type")
  triggeredBy   String?  @map("triggered_by")
  summary       String
  diff          Json
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  threatModel ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)

  @@unique([threatModelId, version])
  @@index([threatModelId])
  @@map("tm_changes")
}

model TmGap {
  id            String    @id @default(cuid())
  threatModelId String    @map("threat_model_id")
  type          String
  severity      Severity
  description   String
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  isResolved    Boolean   @default(false) @map("is_resolved")
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  threatModel ThreatModel @relation(fields: [threatModelId], references: [id], onDelete: Cascade)

  @@index([threatModelId])
  @@index([severity])
  @@index([isResolved])
  @@map("tm_gaps")
}

// ===========================================
// Notification Preferences
// ===========================================

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  type      String   // e.g. "review_completed", "high_risk_detected"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([tenantId])
  @@map("notification_preferences")
}

// ===========================================
// Notifications
// ===========================================

model Notification {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  tenantId      String    @map("tenant_id")
  type          String    // "review_completed", "high_risk_detected", etc.
  title         String    // "Security review completed"
  body          String    // "Review for 'Auth Flow' found 3 high-severity findings"
  linkUrl       String?   @map("link_url") // "/reviews/clxyz123"
  projectId     String?   @map("project_id") // For project-scoped filtering
  sourceEventId String?   @map("source_event_id") // Deduplication key
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceEventId]) // Dedup: PostgreSQL ignores NULLs in unique
  @@index([userId, readAt]) // "Show me unread" query
  @@index([userId, createdAt]) // Paginated history
  @@index([userId, type, projectId, createdAt], map: "notifications_cooldown_idx") // Per-project cooldown check
  @@index([tenantId])
  @@map("notifications")
}

// ─── AI Usage Tracking ──────────────────────────────────────────────────────

model AiUsage {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  model            String   // e.g., "claude-sonnet-4", "claude-haiku-4", "titan-embed-v2"
  operation        String   // e.g., "review-generation", "summary-generation", "risk-classification", "embedding", "threat-model", "project-naming"
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalTokens      Int      @map("total_tokens")
  costCents        Float    @map("cost_cents") // Cost in USD cents (e.g., 1.5 = $0.015)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, operation])
  @@map("ai_usage")
}
